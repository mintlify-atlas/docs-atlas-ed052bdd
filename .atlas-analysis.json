  "keyFeatures": [
    "Join and manage bots across Zoom, Google Meet, and Microsoft Teams",
    "Real-time transcription with multiple provider support",
    "Audio and video recording with customizable settings",
    "Voice agents integration for AI-powered meeting participants",
    "Webhooks for real-time event notifications",
    "Calendar integration for automated bot scheduling",
    "Speech synthesis and chat message capabilities",
    "Participant tracking and event monitoring"
  ],
  "publicApiSurface": [
    "POST /api/v1/bots - Create and join meeting bot",
    "GET /api/v1/bots - List all bots",
    "GET /api/v1/bots/{id} - Get bot details",
    "PATCH /api/v1/bots/{id} - Update bot",
    "DELETE /api/v1/bots/{id} - Delete scheduled bot",
    "POST /api/v1/bots/{id}/leave - Leave meeting",
    "GET /api/v1/bots/{id}/transcript - Get meeting transcript",
    "GET /api/v1/bots/{id}/recording - Get meeting recording",
    "POST /api/v1/bots/{id}/speech - Send speech to meeting",
    "GET /api/v1/bots/{id}/chat_messages - Get chat messages",
    "POST /api/v1/bots/{id}/send_chat_message - Send chat message",
    "GET /api/v1/bots/{id}/participants - List participants",
    "GET /api/v1/bots/{id}/participant_events - Get participant events",
    "POST /api/v1/calendars - Create calendar connection",
    "GET /api/v1/calendar_events - List calendar events",
    "POST /api/v1/zoom_oauth_connections - Create Zoom OAuth connection"
  ]
